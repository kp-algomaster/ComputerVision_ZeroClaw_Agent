# === ZeroClaw CV Agent Configuration ===

# Ollama Vision Models
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=qwen2.5-vl:7b

# Research Sources
ARXIV_CATEGORIES=cs.CV,cs.AI,cs.LG,cs.RO
SEMANTIC_SCHOLAR_API_KEY=

# Web Search (ZeroClaw built-in)
BRAVE_API_KEY=

# LLM Provider (for text generation / summaries)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1

# Outbound HTTPS certificate verification
# false = allow self-signed or intercepted TLS certificates
# true  = require valid public CA certificates
# or set a PEM bundle path to trust a custom CA
CV_SSL_VERIFY=false

# Knowledge Vault
VAULT_PATH=./vault
OBSIDIAN_VAULT_NAME=CV_Research

# Output
OUTPUT_DIR=./output
DIGEST_SCHEDULE=weekly

# Agent
AGENT_LOG_LEVEL=INFO

# ── Powers ──────────────────────────────────────────────────────────────────

# Internet Search — Brave Search API (optional; falls back to DuckDuckGo)
BRAVE_API_KEY=

# Email (SMTP) — send digests and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# HuggingFace Hub
HF_TOKEN=

# Kaggle
KAGGLE_USERNAME=
KAGGLE_KEY=

# GitHub (public repos work without a token; set for private access)
GITHUB_TOKEN=

# Azure ML
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_ML_WORKSPACE=
AZURE_ML_COMPUTE=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# RunPod / GPU Cloud
RUNPOD_API_KEY=

# ── Remote Connections ──────────────────────────────────────────────────────

# Telegram (create bot at t.me/BotFather, get Chat ID via /getUpdates)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord (channel Settings → Integrations → Webhooks → New Webhook)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# WhatsApp Business (Meta Cloud API — developers.facebook.com)
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT=

# Signal (requires signal-cli — github.com/AsamK/signal-cli)
SIGNAL_ENABLED=false
SIGNAL_CLI_PATH=signal-cli
SIGNAL_PHONE_NUMBER=
SIGNAL_RECIPIENT=
